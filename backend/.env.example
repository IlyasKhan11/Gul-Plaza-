# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Environment
NODE_ENV=production
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_prod_db
DB_USER=ecommerce_user
DB_PASSWORD=your_secure_database_password_here
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_DB=0
REDIS_TLS=true

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_in_production
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d

# CORS Configuration
FRONTEND_URL=https://your-frontend-domain.com
ADMIN_URL=https://your-admin-domain.com
API_URL=https://your-api-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_ORDER_MAX=20

# Logging
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=5242880
LOG_FILE_MAX_FILES=5

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_minimum_32_characters
COOKIE_SECRET=your_cookie_secret_minimum_32_characters

# Email Configuration (for notifications)
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@your-domain.com

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf
UPLOAD_PATH=uploads/

# Payment Configuration
PAYMENT_PROVIDER=stripe
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
WEBHOOK_SECRET=your_webhook_secret

# Monitoring and Analytics
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=your_sentry_dsn_here

# Cache Configuration
CACHE_TTL_USER=3600
CACHE_TTL_PRODUCT=1800
CACHE_TTL_CATEGORY=7200
CACHE_TTL_ORDER=600

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1

# Company-specific configurations
COMPANY_NAME=Your Company Name
COMPANY_EMAIL=support@your-domain.com
COMPANY_PHONE=+1-555-123-4567
COMPANY_ADDRESS=123 Business St, City, State 12345

# Development only (remove in production)
DEV_MODE=false
DEBUG_MODE=false
