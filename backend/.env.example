# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Environment
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=postgres
DB_PASSWORD=your_company_database_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_company_redis_password

# JWT Configuration
JWT_SECRET=your_company_super_secret_jwt_key_change_in_production
JWT_EXPIRE=1h

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Company-specific configurations
COMPANY_NAME=your_company_name
API_BASE_URL=https://your-company-api.com
